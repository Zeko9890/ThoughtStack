rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Secure the /users collection
    match /users/{userId} {
      
      // 1. The root profile document
      // Only the authenticated user who owns the document can read or write it
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // 2. All nested subcollections (thoughts, decisions, reviews, etc.)
      // Secures all deeper data belonging to that user
      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
    }
    
    // Default fallback: deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
